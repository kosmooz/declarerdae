# Database (use Docker internal network in production)
DATABASE_URL=postgresql://declarerdae:CHANGE_ME_STRONG_PASSWORD@postgres:5432/declarerdae

# JWT (generate with: openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# Environment
NODE_ENV=production

# Frontend URL (your production domain)
FRONTEND_URL=https://star-aid.fr

# CORS origin
CORS_ORIGIN=https://star-aid.fr

# Yousign
YOUSIGN_API_KEY=your_yousign_api_key
YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3
